# ==============================================================================
# Variables de entorno — appclima-python
# ==============================================================================
# Copia este archivo a `.env` y completa los valores para tu entorno.
#   cp .env.example .env
#
# NUNCA subas tu archivo `.env` con valores reales al repositorio.
# Ver SECURITY.md y docs/conventions/secrets.md.
# ==============================================================================

# ── OpenWeatherMap ────────────────────────────────────────────────────────
# Clave de la API de OpenWeatherMap. Necesaria para las etapas 6 y 7.
# Obtén una gratis en: https://home.openweathermap.org/api_keys
API_KEY=
# URL base del servicio (normalmente no necesitas cambiarla).
API_URL=http://api.openweathermap.org/data/2.5/weather

# ── Logging ───────────────────────────────────────────────────────────────
# Nivel de log: debug | info | warn | error
LOG_LEVEL=info
